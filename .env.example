# ===========================================
# IBS-Pro - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ---- Database (Supabase) ----
# Get from Supabase > Settings > Database > Connection string (URI)
# IMPORTANT: Use the PORT 6543 pooler URL with ?pgbouncer=true for runtime
# The password should be URL-encoded (replace @ with %40)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[ENCODED-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ---- App ----
NEXT_PUBLIC_APP_URL=https://your-domain.com
